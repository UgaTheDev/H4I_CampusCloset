# Supabase — get these from your Supabase project dashboard (Settings > API)
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stadia Maps — get a domain-restricted key from https://stadiamaps.com/
# Restrict the key to your production domain in the Stadia dashboard.
# Omit or leave blank to use the unauthenticated tile endpoint (localhost dev only).
NEXT_PUBLIC_STADIA_MAPS_API_KEY="your-stadia-maps-api-key"

# Google OAuth (configure in Supabase Dashboard > Auth > Providers > Google)
# You need a Google Cloud OAuth client ID and secret:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: https://your-project.supabase.co/auth/v1/callback
# 4. Paste client ID and secret into Supabase Dashboard (not here — Supabase stores them)
